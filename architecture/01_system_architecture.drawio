<mxfile host="65bd71144e">
    <diagram id="sys-arch" name="System Architecture">
        <mxGraphModel dx="1910" dy="2418" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2400" pageHeight="1600" background="#ffffff" math="0" shadow="0">
            <root>
                <mxCell id="0"/>
                <mxCell id="1" parent="0"/>
                <mxCell id="title" value="&lt;font style=&quot;font-size:22px&quot;&gt;&lt;b&gt;End-to-End Autonomous Driving - MLOps System Architecture&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:12px;color:#666&quot;&gt;Closed-Loop Evaluation | Continuous Retraining | Digital Twin Validation | Fleet Deployment&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;" parent="1" vertex="1">
                    <mxGeometry x="550" y="-60" width="700" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="sec1_bg" value="" style="rounded=1;whiteSpace=wrap;fillColor=#E3F2FD;strokeColor=#1565C0;strokeWidth=2;dashed=1;" parent="1" vertex="1">
                    <mxGeometry x="40" y="100" width="560" height="340" as="geometry"/>
                </mxCell>
                <mxCell id="sec1_title" value="&lt;font style=&quot;font-size:14px;color:#1565C0&quot;&gt;&lt;b&gt;DIGITAL TWIN SIMULATION&lt;/b&gt;&lt;/font&gt;" style="text;html=1;align=left;" parent="1" vertex="1">
                    <mxGeometry x="60" y="110" width="300" height="25" as="geometry"/>
                </mxCell>
                <mxCell id="c1" value="&lt;b&gt;&lt;font style=&quot;font-size: 12px; color: rgb(255, 255, 255);&quot;&gt;CARLA Simulator&lt;/font&gt;&lt;/b&gt;&lt;hr&gt;&lt;font style=&quot;font-size: 12px; color: rgb(255, 255, 255);&quot;&gt;Open-source 3D driving simulator.&lt;br&gt;Renders realistic urban environments&lt;br&gt;with physics-based vehicle dynamics.&lt;br&gt;&lt;i style=&quot;&quot;&gt;Version: 0.9.x | UE4 Engine&lt;/i&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1565C0;fontColor=#fff;strokeColor=#FFFFFF;align=center;spacing=8;fontSize=10;" parent="1" vertex="1">
                    <mxGeometry x="60" y="150" width="240" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="c2" value="&lt;b&gt;&lt;font style=&quot;font-size: 12px; color: rgb(255, 255, 255);&quot;&gt;Route &amp;amp; Scenario Manager&lt;/font&gt;&lt;/b&gt;&lt;hr&gt;&lt;font style=&quot;font-size: 12px; color: rgb(255, 255, 255);&quot;&gt;Loads predefined driving routes&lt;br&gt;(220 Bench2Drive scenarios).&lt;br&gt;Configures weather, time-of-day,&lt;br&gt;traffic density, and road events.&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1976D2;fontColor=#fff;strokeColor=none;align=center;spacing=8;fontSize=10;" parent="1" vertex="1">
                    <mxGeometry x="340" y="150" width="240" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="c3" value="&lt;b&gt;&lt;font style=&quot;font-size: 12px; color: rgb(255, 255, 255);&quot;&gt;Sensor Suite&lt;/font&gt;&lt;/b&gt;&lt;hr&gt;&lt;font style=&quot;font-size: 12px; color: rgb(255, 255, 255);&quot;&gt;Simulates vehicle-mounted sensors:&lt;br&gt;- 6x RGB Cameras (1600x900)&lt;br&gt;- LiDAR point cloud&lt;br&gt;- IMU / GPS / Speedometer&lt;br&gt;- Collision &amp;amp; Lane invasion detectors&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1565C0;fontColor=#fff;strokeColor=none;align=center;spacing=8;fontSize=10;" parent="1" vertex="1">
                    <mxGeometry x="60" y="295" width="240" height="130" as="geometry"/>
                </mxCell>
                <mxCell id="c4" value="&lt;b&gt;&lt;font style=&quot;color: rgb(255, 255, 255); font-size: 12px;&quot;&gt;Traffic Participants&lt;/font&gt;&lt;/b&gt;&lt;hr&gt;&lt;font style=&quot;color: rgb(255, 255, 255); font-size: 12px;&quot;&gt;Spawns NPC vehicles, pedestrians,&lt;br&gt;cyclists with autopilot behavior.&lt;br&gt;Generates dynamic interactions:&lt;br&gt;cut-ins, jaywalking, emergency&lt;br&gt;vehicles, construction zones.&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1976D2;fontColor=#fff;strokeColor=none;align=center;spacing=8;fontSize=10;" parent="1" vertex="1">
                    <mxGeometry x="340" y="295" width="240" height="130" as="geometry"/>
                </mxCell>
                <mxCell id="sec2_bg" value="" style="rounded=1;whiteSpace=wrap;fillColor=#FFEBEE;strokeColor=#C62828;strokeWidth=2;dashed=1;" parent="1" vertex="1">
                    <mxGeometry x="660" y="100" width="560" height="340" as="geometry"/>
                </mxCell>
                <mxCell id="sec2_title" value="&lt;font style=&quot;font-size:14px;color:#C62828&quot;&gt;&lt;b&gt;E2E DRIVING MODEL (PERCEPTION + PLANNING)&lt;/b&gt;&lt;/font&gt;" style="text;html=1;align=left;" parent="1" vertex="1">
                    <mxGeometry x="680" y="110" width="450" height="25" as="geometry"/>
                </mxCell>
                <mxCell id="m1" value="&lt;b&gt;&lt;font style=&quot;color: rgb(255, 255, 255); font-size: 12px;&quot;&gt;Image Backbone&lt;/font&gt;&lt;/b&gt;&lt;hr&gt;&lt;font style=&quot;color: rgb(255, 255, 255); font-size: 12px;&quot;&gt;Deep CNN (e.g., ResNet-50) extracts&lt;br&gt;multi-scale visual features from&lt;br&gt;all 6 camera views simultaneously.&lt;br&gt;&lt;i style=&quot;&quot;&gt;Output: 2D feature maps per view&lt;/i&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C62828;fontColor=#fff;strokeColor=none;align=center;spacing=8;fontSize=10;" parent="1" vertex="1">
                    <mxGeometry x="680" y="150" width="240" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="m2" value="&lt;b&gt;&lt;font style=&quot;color: rgb(255, 255, 255); font-size: 12px;&quot;&gt;BEV Encoder&lt;/font&gt;&lt;/b&gt;&lt;hr&gt;&lt;font style=&quot;color: rgb(255, 255, 255); font-size: 12px;&quot;&gt;Transforms 2D image features into&lt;br&gt;3D Bird&#39;s-Eye-View representation&lt;br&gt;using deformable attention.&lt;br&gt;&lt;i style=&quot;&quot;&gt;Output: unified BEV feature grid&lt;/i&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D32F2F;fontColor=#fff;strokeColor=none;align=center;spacing=8;fontSize=10;" parent="1" vertex="1">
                    <mxGeometry x="960" y="150" width="240" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="2" value="" style="edgeStyle=none;html=1;" edge="1" parent="1" source="m3" target="m1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="m3" value="&lt;b&gt;&lt;font style=&quot;font-size: 12px; color: rgb(255, 255, 255);&quot;&gt;Detection &amp;amp; Map Head&lt;/font&gt;&lt;/b&gt;&lt;hr&gt;&lt;font style=&quot;font-size: 12px; color: rgb(255, 255, 255);&quot;&gt;Predicts 3D bounding boxes for&lt;br&gt;vehicles, pedestrians, cyclists.&lt;br&gt;Predicts lane boundaries, road&lt;br&gt;edges, and drivable area map.&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C62828;fontColor=#fff;strokeColor=none;align=center;spacing=8;fontSize=10;" parent="1" vertex="1">
                    <mxGeometry x="680" y="295" width="240" height="130" as="geometry"/>
                </mxCell>
                <mxCell id="m4" value="&lt;b&gt;&lt;font style=&quot;color: rgb(255, 255, 255); font-size: 12px;&quot;&gt;Trajectory Planner&lt;/font&gt;&lt;/b&gt;&lt;hr&gt;&lt;font style=&quot;color: rgb(255, 255, 255); font-size: 12px;&quot;&gt;Generates multiple candidate&lt;br&gt;future trajectories using a VAE.&lt;br&gt;Scores each trajectory for safety&lt;br&gt;(collision, boundary, direction).&lt;br&gt;&lt;i style=&quot;&quot;&gt;Output: optimal ego trajectory&lt;/i&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D32F2F;fontColor=#fff;strokeColor=none;align=center;spacing=8;fontSize=10;" parent="1" vertex="1">
                    <mxGeometry x="960" y="295" width="240" height="130" as="geometry"/>
                </mxCell>
                <mxCell id="sec3_bg" value="" style="rounded=1;whiteSpace=wrap;fillColor=#E8F5E9;strokeColor=#2E7D32;strokeWidth=2;dashed=1;" parent="1" vertex="1">
                    <mxGeometry x="1280" y="100" width="560" height="340" as="geometry"/>
                </mxCell>
                <mxCell id="sec3_title" value="&lt;font style=&quot;font-size:14px;color:#2E7D32&quot;&gt;&lt;b&gt;DATA PIPELINE&lt;/b&gt;&lt;/font&gt;" style="text;html=1;align=left;" parent="1" vertex="1">
                    <mxGeometry x="1300" y="110" width="200" height="25" as="geometry"/>
                </mxCell>
                <mxCell id="d1" value="&lt;b&gt;&lt;font style=&quot;color: rgb(255, 255, 255); font-size: 12px;&quot;&gt;Data Lake (Cloud Storage)&lt;/font&gt;&lt;/b&gt;&lt;hr&gt;&lt;font style=&quot;color: rgb(255, 255, 255); font-size: 12px;&quot;&gt;Centralized storage for all driving&lt;br&gt;data: camera frames, LiDAR scans,&lt;br&gt;CAN bus logs, annotations.&lt;br&gt;&lt;i style=&quot;&quot;&gt;S3 / Azure Blob / GCS&lt;/i&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2E7D32;fontColor=#fff;strokeColor=none;align=center;spacing=8;fontSize=10;" parent="1" vertex="1">
                    <mxGeometry x="1300" y="150" width="240" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="d2" value="&lt;b&gt;&lt;font style=&quot;font-size: 12px; color: rgb(255, 255, 255);&quot;&gt;Feature Store&lt;/font&gt;&lt;/b&gt;&lt;hr&gt;&lt;font style=&quot;font-size: 12px; color: rgb(255, 255, 255);&quot;&gt;Pre-computed embeddings, BEV&lt;br&gt;features, and curated labels for&lt;br&gt;fast training data retrieval.&lt;br&gt;&lt;i style=&quot;&quot;&gt;Feast / Tecton / Custom&lt;/i&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#388E3C;fontColor=#fff;strokeColor=none;align=center;spacing=8;fontSize=10;" parent="1" vertex="1">
                    <mxGeometry x="1580" y="150" width="240" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="d3" value="&lt;b&gt;&lt;font style=&quot;font-size: 12px; color: rgb(255, 255, 255);&quot;&gt;Data Versioning&lt;/font&gt;&lt;/b&gt;&lt;hr&gt;&lt;font style=&quot;font-size: 12px; color: rgb(255, 255, 255);&quot;&gt;Tracks dataset versions tied to&lt;br&gt;model experiments. Ensures&lt;br&gt;reproducibility of training runs.&lt;br&gt;&lt;i style=&quot;&quot;&gt;DVC / LakeFS / Delta Lake&lt;/i&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2E7D32;fontColor=#fff;strokeColor=none;align=center;spacing=8;fontSize=10;" parent="1" vertex="1">
                    <mxGeometry x="1300" y="295" width="240" height="130" as="geometry"/>
                </mxCell>
                <mxCell id="d4" value="&lt;b&gt;&lt;font style=&quot;font-size: 12px; color: rgb(255, 255, 255);&quot;&gt;Auto Annotation Pipeline&lt;/font&gt;&lt;/b&gt;&lt;hr&gt;&lt;font style=&quot;font-size: 12px; color: rgb(255, 255, 255);&quot;&gt;Automatic labeling of new drive&lt;br&gt;logs using teacher models and&lt;br&gt;CARLA ground truth. Human-in-&lt;br&gt;the-loop review for edge cases.&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#388E3C;fontColor=#fff;strokeColor=none;align=center;spacing=8;fontSize=10;" parent="1" vertex="1">
                    <mxGeometry x="1580" y="295" width="240" height="130" as="geometry"/>
                </mxCell>
                <mxCell id="sec4_bg" value="" style="rounded=1;whiteSpace=wrap;fillColor=#F3E5F5;strokeColor=#6A1B9A;strokeWidth=2;dashed=1;" parent="1" vertex="1">
                    <mxGeometry x="40" y="500" width="870" height="340" as="geometry"/>
                </mxCell>
                <mxCell id="sec4_title" value="&lt;font style=&quot;font-size:14px;color:#6A1B9A&quot;&gt;&lt;b&gt;MLOps / CI-CD PIPELINE&lt;/b&gt;&lt;/font&gt;" style="text;html=1;align=left;" parent="1" vertex="1">
                    <mxGeometry x="60" y="510" width="250" height="25" as="geometry"/>
                </mxCell>
                <mxCell id="o1" value="&lt;b&gt;&lt;font style=&quot;color: rgb(255, 255, 255); font-size: 12px;&quot;&gt;Git Repository&lt;/font&gt;&lt;/b&gt;&lt;hr&gt;&lt;font style=&quot;font-size: 12px;&quot;&gt;&lt;font style=&quot;color: rgb(255, 255, 255);&quot;&gt;Version-controlled source code,&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;color: rgb(255, 255, 255);&quot;&gt;configs, and DVC pointers to&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;color: rgb(255, 255, 255);&quot;&gt;datasets and model artifacts.&lt;/font&gt;&lt;br&gt;&lt;i&gt;&lt;font style=&quot;color: rgb(255, 255, 255);&quot;&gt;GitHub / GitLab + DVC&lt;/font&gt;&lt;/i&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#6A1B9A;fontColor=#fff;strokeColor=none;align=center;spacing=8;fontSize=10;" parent="1" vertex="1">
                    <mxGeometry x="60" y="550" width="240" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="o2" value="&lt;b&gt;&lt;font style=&quot;font-size: 12px; color: rgb(255, 255, 255);&quot;&gt;CI/CD Pipeline&lt;/font&gt;&lt;/b&gt;&lt;hr&gt;&lt;font style=&quot;font-size: 12px; color: rgb(255, 255, 255);&quot;&gt;Automated build, test, and deploy&lt;br&gt;on every code or data change.&lt;br&gt;Runs linting, unit tests, data&lt;br&gt;validation, and container builds.&lt;br&gt;&lt;i style=&quot;&quot;&gt;GitHub Actions / Jenkins&lt;/i&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#7B1FA2;fontColor=#fff;strokeColor=none;align=center;spacing=8;fontSize=10;" parent="1" vertex="1">
                    <mxGeometry x="340" y="550" width="240" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="o3" value="&lt;b&gt;&lt;font style=&quot;color: rgb(255, 255, 255); font-size: 12px;&quot;&gt;Training Infrastructure&lt;/font&gt;&lt;/b&gt;&lt;hr&gt;&lt;font style=&quot;font-size: 12px;&quot;&gt;&lt;font style=&quot;color: rgb(255, 255, 255);&quot;&gt;Scalable GPU compute for&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;color: rgb(255, 255, 255);&quot;&gt;distributed model training.&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;color: rgb(255, 255, 255);&quot;&gt;Supports multi-node, mixed&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;color: rgb(255, 255, 255);&quot;&gt;precision, and checkpointing.&lt;/font&gt;&lt;br&gt;&lt;i style=&quot;&quot;&gt;&lt;font style=&quot;color: rgb(255, 255, 255);&quot;&gt;AWS / GCP / On-prem cluster&lt;/font&gt;&lt;/i&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#6A1B9A;fontColor=#fff;strokeColor=none;align=center;spacing=8;fontSize=10;" parent="1" vertex="1">
                    <mxGeometry x="620" y="550" width="270" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="o4" value="&lt;b&gt;&lt;font style=&quot;color: rgb(255, 255, 255); font-size: 12px;&quot;&gt;Experiment Tracking&lt;/font&gt;&lt;/b&gt;&lt;hr&gt;&lt;font style=&quot;font-size: 12px;&quot;&gt;&lt;font style=&quot;color: rgb(255, 255, 255);&quot;&gt;Logs hyperparameters, metrics,&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;color: rgb(255, 255, 255);&quot;&gt;loss curves, and model artifacts&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;color: rgb(255, 255, 255);&quot;&gt;for every training run.&lt;/font&gt;&lt;br&gt;&lt;i style=&quot;&quot;&gt;&lt;font style=&quot;color: rgb(255, 255, 255);&quot;&gt;MLflow / Weights &amp;amp; Biases&lt;/font&gt;&lt;/i&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#7B1FA2;fontColor=#fff;strokeColor=none;align=center;spacing=8;fontSize=10;" parent="1" vertex="1">
                    <mxGeometry x="60" y="695" width="240" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="o5" value="&lt;b&gt;&lt;font style=&quot;font-size: 12px; color: rgb(255, 255, 255);&quot;&gt;Model Registry&lt;/font&gt;&lt;/b&gt;&lt;hr&gt;&lt;font style=&quot;font-size: 12px;&quot;&gt;&lt;font style=&quot;color: rgb(255, 255, 255);&quot;&gt;Stores trained model versions&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;color: rgb(255, 255, 255);&quot;&gt;with metadata (dataset, metrics).&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;color: rgb(255, 255, 255);&quot;&gt;Stage management: dev, staging,&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;color: rgb(255, 255, 255);&quot;&gt;production, archived.&lt;/font&gt;&lt;br&gt;&lt;i style=&quot;&quot;&gt;&lt;font style=&quot;color: rgb(255, 255, 255);&quot;&gt;MLflow Registry / SageMaker&lt;/font&gt;&lt;/i&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#6A1B9A;fontColor=#fff;strokeColor=none;align=center;spacing=8;fontSize=10;" parent="1" vertex="1">
                    <mxGeometry x="340" y="695" width="240" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="o6" value="&lt;b&gt;&lt;font style=&quot;color: rgb(255, 255, 255); font-size: 12px;&quot;&gt;Validation Gate&lt;/font&gt;&lt;/b&gt;&lt;hr&gt;&lt;font style=&quot;color: rgb(255, 255, 255); font-size: 12px;&quot;&gt;Automated quality checks before&lt;br&gt;promotion. Runs digital twin eval&lt;br&gt;on CARLA, compares vs baseline.&lt;br&gt;Requires human approval for&lt;br&gt;production deployment.&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#7B1FA2;fontColor=#fff;strokeColor=none;align=center;spacing=8;fontSize=10;" parent="1" vertex="1">
                    <mxGeometry x="620" y="695" width="270" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="sec5_bg" value="" style="rounded=1;whiteSpace=wrap;fillColor=#E0F2F1;strokeColor=#00695C;strokeWidth=2;dashed=1;" parent="1" vertex="1">
                    <mxGeometry x="970" y="500" width="870" height="340" as="geometry"/>
                </mxCell>
                <mxCell id="sec5_title" value="&lt;font style=&quot;font-size:14px;color:#00695C&quot;&gt;&lt;b&gt;MONITORING &amp; FEEDBACK&lt;/b&gt;&lt;/font&gt;" style="text;html=1;align=left;" parent="1" vertex="1">
                    <mxGeometry x="990" y="510" width="250" height="25" as="geometry"/>
                </mxCell>
                <mxCell id="n1" value="&lt;span&gt;Performance KPIs&lt;/span&gt;&lt;hr&gt;Tracks driving score, collision&lt;br&gt;rate, route completion, lateral&lt;br&gt;deviation, speed compliance.&lt;br&gt;&lt;i&gt;Updated per route / per fleet&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0BD0B9;fontColor=#000000;strokeColor=none;align=center;spacing=8;fontSize=12;fontStyle=0" parent="1" vertex="1">
                    <mxGeometry x="990" y="550" width="240" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="n2" value="&lt;span&gt;Model Drift Detection&lt;/span&gt;&lt;hr&gt;Monitors input data distribution&lt;br&gt;shift (new road types, weather).&lt;br&gt;Detects prediction confidence&lt;br&gt;degradation over time.&lt;br&gt;&lt;i&gt;Evidently AI / Custom&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0BD0B9;fontColor=#000000;strokeColor=none;align=center;spacing=8;fontSize=12;fontStyle=0" parent="1" vertex="1">
                    <mxGeometry x="1270" y="550" width="240" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="n3" value="&lt;span&gt;A/B Testing &amp;amp; Shadow Mode&lt;/span&gt;&lt;hr&gt;Runs new model in parallel with&lt;br&gt;current production model. Compares&lt;br&gt;decisions without affecting vehicle&lt;br&gt;control. Validates before rollout." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0BD0B9;fontColor=#000000;strokeColor=none;align=center;spacing=8;fontSize=12;fontStyle=0" parent="1" vertex="1">
                    <mxGeometry x="1550" y="550" width="270" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="n4" value="&lt;span&gt;Dashboard&lt;/span&gt;&lt;hr&gt;Real-time visualization of fleet&lt;br&gt;health, model performance, and&lt;br&gt;safety metrics across all vehicles.&lt;br&gt;&lt;i&gt;Grafana / Custom React UI&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0BD0B9;fontColor=#000000;strokeColor=none;align=center;spacing=8;fontSize=12;fontStyle=0" parent="1" vertex="1">
                    <mxGeometry x="990" y="695" width="240" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="n5" value="&lt;span&gt;Alert System&lt;/span&gt;&lt;hr&gt;Triggers notifications when KPIs&lt;br&gt;breach thresholds (e.g., collision&lt;br&gt;rate &amp;gt; X). Auto-triggers retrain&lt;br&gt;pipeline on critical drift alerts.&lt;br&gt;&lt;i&gt;PagerDuty / Slack / Email&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0BD0B9;fontColor=#000000;strokeColor=none;align=center;spacing=8;fontSize=12;fontStyle=0" parent="1" vertex="1">
                    <mxGeometry x="1270" y="695" width="240" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="n6" value="&lt;span&gt;Log Analytics&lt;/span&gt;&lt;hr&gt;Aggregates and indexes all system&lt;br&gt;logs: inference latency, sensor&lt;br&gt;errors, control anomalies.&lt;br&gt;Enables root-cause analysis.&lt;br&gt;&lt;i&gt;ELK Stack / CloudWatch&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0BD0B9;fontColor=#000000;strokeColor=none;align=center;spacing=8;fontSize=12;fontStyle=0" parent="1" vertex="1">
                    <mxGeometry x="1550" y="695" width="270" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="sec6_bg" value="" style="rounded=1;whiteSpace=wrap;fillColor=#FFF8E1;strokeColor=#E65100;strokeWidth=2;dashed=1;" parent="1" vertex="1">
                    <mxGeometry x="40" y="900" width="1800" height="200" as="geometry"/>
                </mxCell>
                <mxCell id="sec6_title" value="&lt;font style=&quot;font-size:14px;color:#E65100&quot;&gt;&lt;b&gt;DEPLOYMENT &amp; VEHICLE INTEGRATION&lt;/b&gt;&lt;/font&gt;" style="text;html=1;align=left;" parent="1" vertex="1">
                    <mxGeometry x="60" y="910" width="350" height="25" as="geometry"/>
                </mxCell>
                <mxCell id="p1" value="&lt;b&gt;Model Optimization&lt;/b&gt;&lt;hr&gt;Converts PyTorch model to&lt;br&gt;TensorRT/ONNX for 10x&lt;br&gt;faster inference on edge.&lt;br&gt;&lt;i&gt;Quantization + Pruning&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E65100;fontColor=#fff;strokeColor=none;align=center;spacing=6;fontSize=12;" parent="1" vertex="1">
                    <mxGeometry x="60" y="945" width="210" height="130" as="geometry"/>
                </mxCell>
                <mxCell id="p2" value="&lt;b&gt;Edge Deployment&lt;/b&gt;&lt;hr&gt;Deploys optimized model to&lt;br&gt;in-vehicle compute platform.&lt;br&gt;Real-time inference at 20Hz.&lt;br&gt;&lt;i&gt;NVIDIA Orin / Xavier AGX&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EF6C00;fontColor=#fff;strokeColor=none;align=center;spacing=6;fontSize=12;" parent="1" vertex="1">
                    <mxGeometry x="310" y="945" width="210" height="130" as="geometry"/>
                </mxCell>
                <mxCell id="p3" value="&lt;b&gt;Vehicle ECU&lt;/b&gt;&lt;hr&gt;Receives planned trajectory,&lt;br&gt;converts to actuator commands&lt;br&gt;via CAN bus interface.&lt;br&gt;&lt;i&gt;Throttle / Steer / Brake&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E65100;fontColor=#fff;strokeColor=none;align=center;spacing=6;fontSize=12;" parent="1" vertex="1">
                    <mxGeometry x="560" y="945" width="210" height="130" as="geometry"/>
                </mxCell>
                <mxCell id="p4" value="&lt;b&gt;Vehicle Sensors&lt;/b&gt;&lt;hr&gt;Physical camera, LiDAR, radar&lt;br&gt;hardware mounted on vehicle.&lt;br&gt;Streams data to edge compute.&lt;br&gt;&lt;i&gt;6 Cam + LiDAR + 5 Radar&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EF6C00;fontColor=#fff;strokeColor=none;align=center;spacing=6;fontSize=12;" parent="1" vertex="1">
                    <mxGeometry x="810" y="945" width="210" height="130" as="geometry"/>
                </mxCell>
                <mxCell id="p5" value="&lt;b&gt;Data Recorder&lt;/b&gt;&lt;hr&gt;Continuously logs sensor data,&lt;br&gt;model predictions, vehicle state,&lt;br&gt;and safety events to onboard&lt;br&gt;storage for later upload." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E65100;fontColor=#fff;strokeColor=none;align=center;spacing=6;fontSize=12;" parent="1" vertex="1">
                    <mxGeometry x="1060" y="945" width="210" height="130" as="geometry"/>
